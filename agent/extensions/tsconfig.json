{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noEmit": true,
    "allowImportingTsExtensions": true
  },
  "include": ["public/**/*.ts", "private/**/*.ts"],
  "exclude": [
    "private/browser-bridge/browser-extension/src/content.ts",
    "private/browser-bridge/browser-extension/src/content/**/*.ts"
  ]
}
