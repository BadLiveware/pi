{
  "name": "pi-personal-workflow-extensions",
  "version": "0.1.0",
  "description": "Local workspace for public and private Pi workflow extensions.",
  "private": true,
  "type": "module",
  "workspaces": [
    "public/*",
    "private/*"
  ],
  "keywords": [
    "pi-package",
    "pi-extension"
  ],
  "pi": {
    "extensions": [
      "./public/compaction-continue/index.ts",
      "./public/pr-upstream-status/index.ts",
      "./public/footer-framework/index.ts",
      "./public/model-catalog/index.ts",
      "./private/stardock/index.ts",
      "./private/code-intelligence/index.ts"
    ],
    "skills": [
      "./private/stardock/skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --experimental-strip-types --test \"public/**/*.test.ts\" \"private/**/*.test.ts\"",
    "test:footer": "node --experimental-strip-types --test public/footer-framework/*.test.ts",
    "pack:public": "./scripts/pack-public.sh"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "^0.70.2",
    "@mariozechner/pi-agent-core": "^0.70.2",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "@mariozechner/pi-tui": "^0.70.2",
    "@types/node": "^22.0.0",
    "typebox": "^1.1.33",
    "typescript": "^5.9.0"
  },
  "packageManager": "npm@10"
}
