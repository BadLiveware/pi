{
  "$schema": "./extensions/public/multi-harness-compatibility/config.schema.json",
  "defaultProfile": "personal",
  "profiles": {
    "global": {
      "skillDirs": ["~/.local/share/omarchy/default/omarchy-skill/SKILL.md"]
    },
    "work": {
      "inherit": ["global"],
      "match": {
        "paths": ["~/code/tradera/**"]
      },
      "roots": ["~/code/tradera"],
      "pi": true,
      "claude": true,
      "cursor": true,
      "agents": true
    },
    "personal": {
      "inherit": ["global"],
      "match": {
        "paths": ["~/code/**"]
      },
      "pi": true,
      "claude": true,
      "cursor": true,
      "agents": true
    }
  }
}
